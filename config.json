{
  "opening_hours": {
    "timezone": "Europe/Paris",
    "start": "08:00",
    "end": "18:00",
    "off_hours_cycle_seconds": 300
  },
  "detection": {
    "motion_threshold": 35,
    "min_area": 800,
    "stationary_threshold": 30,
